pipeline{
    
    agent{label "supi"}
    
    stages{
       stage("code"){
          steps{
             echo "This is code cloning" 
             git url: "https://github.com/anim-lindevs/Java-Docker.git", branch:"main"
             echo "code cloning successful"
          } 
       }
       stage("build"){
           steps{
              echo "This is building the code" 
              sh "docker build -t java-app:latest ."
              echo "image build successfully"
           }
       }
       stage("test"){
           steps{
             echo "This is testing the code"  
           }
       }
       stage("deploy"){
           steps{
             echo "This is deploying the code"  
             sh "docker compose -f Docker.yaml up -d"
             echo "docker container running sunccessfully"
           }
       }
    }
}