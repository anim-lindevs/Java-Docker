@Library("shared") _
pipeline{
    
    agent{label "supi"}
    
    stages{
        stage("Hello"){
            steps{
                script{
                    hello()
                }
            }
        }
       stage("code"){
          steps{
              script{
               gitclone("https://github.com/anim-lindevs/Java-Docker.git","main")  
              }
             
          } 
       }
       stage("build"){
           steps{
              script{
                  build("java-app", "latest")
              }
           }
       }
       stage("push image"){
           steps{
               script{
                   docker_push("java-app", "latest", "animlindevs")
            
             }
           }
       }
       stage("deploy"){
           steps{
             sh "docker compose down && docker compose -f Docker.yaml up -d"
           }
       }
   
    }
}
